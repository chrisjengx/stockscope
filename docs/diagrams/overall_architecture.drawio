        <!-- Arrows: A0→A3→A1+A4→A5→A7→FL→Report -->
        <mxCell id="a0_a3" style="edgeStyle=none;strokeColor=#a855f7;endArrow=classic;strokeWidth=2;" edge="1" parent="1" source="agent0" target="agent3">
