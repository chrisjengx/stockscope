        <mxCell id="fl_rpt" style="edgeStyle=none;strokeColor=#ec4899;endArrow=classic;" edge="1" parent="1" source="fl" target="rpt">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- A2 → DB → A5 data flow -->
        <mxCell id="a2_db" style="edgeStyle=none;strokeColor=#f59e0b;strokeDasharray=4;endArrow=classic;fontColor=#64748b;fontSize=9;" edge="1" parent="1" source="a2worker" target="agent5">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="225" y="180"/><mxPoint x="415" y="180"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="a2_label" value="A2报告→A5读取" style="text;fontSize=9;fontColor=#f59e0b;fillColor=none;" vertex="1" parent="1">
